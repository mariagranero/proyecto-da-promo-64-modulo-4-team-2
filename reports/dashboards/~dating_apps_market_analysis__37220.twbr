  <worksheets>
    <worksheet name='% incoherencias'>
      <layout-options>
        <title>
          <formatted-text>
            <run>% Incoherencias Rating vs Sentimiento</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='dating_app_reviews_sentiment (2)' name='federated.0t56jqx1rdm2t51dbjof80ad19dj' />
          </datasources>
          <datasource-dependencies datasource='federated.0t56jqx1rdm2t51dbjof80ad19dj'>
            <column caption=' Incongruencia rating-sentimiento' datatype='string' name='[Calculation_1463768975011861]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [rating] &gt;= 4 AND [sentiment] = &apos;negative&apos; THEN &apos;Rating alto, texto negativo&apos;ELSEIF [rating] &lt;= 2 AND [sentiment] = &apos;positive&apos; THEN &apos;Rating bajo, texto positivo&apos;ELSE &apos;Coherente&apos;END' />
            </column>
            <column caption='% incoherente' datatype='integer' name='[Calculation_1463768979566614]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1463768975011861]&lt;&gt;&apos;Coherente&apos; THEN 1 ELSE 0 END' />
            </column>
            <column caption='App' datatype='string' name='[app]' role='dimension' type='nominal' />
