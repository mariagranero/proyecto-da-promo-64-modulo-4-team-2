          </zone>
          <zone forceUpdate='true' h='66178' id='189' type-v2='text' w='43508' x='15047' y='22833'>
            <formatted-text>
              <run bold='true' fontcolor='#000000' fontsize='20'>🎯 Enfoque del Proyecto</run>
              <run>Æ&#10;&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>📊 </run>
              <run bold='true' fontcolor='#000000' fontsize='12'>Análisis 360º del mercado de apps de citas</run>
              <run fontcolor='#000000' fontsize='12'>Æ                                                                                                                                                                                                                                                                           </run>
              <run fontcolor='#000000' fontsize='11'>→ Combinando comportamiento y percepción.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>📍</run>
              <run bold='true' fontcolor='#000000' fontsize='12'>Dimensión mercado España (dataset sintético autocreado)</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='11'>→ Perfil de usuario, nivel de actividad y eficiencia del funnel (del swipe a la cita).</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>🌍 </run>
              <run bold='true' fontcolor='#000000' fontsize='12'>Dimensión reputacional internacional (dataset de reviews)</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='11'>→ Rating, evolución temporal y análisis de sentimiento.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>🔎 </run>
              <run bold='true' fontcolor='#000000' fontsize='12'>Visión integrada</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='11'>→ Entender no solo cómo funciona el mercado, sino cómo lo viven los usuarios.</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
