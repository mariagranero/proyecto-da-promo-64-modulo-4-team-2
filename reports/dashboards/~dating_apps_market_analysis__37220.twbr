      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0t56jqx1rdm2t51dbjof80ad19dj].[avg:Calculation_1463768974569490:qk]&quot;' value='Sentimiento positivo medio' />
          <alias key='&quot;[federated.0t56jqx1rdm2t51dbjof80ad19dj].[avg:rating:qk]&quot;' value='Rating medio' />
        </aliases>
      </column>
      <column caption='Review positiva (0/1)' datatype='integer' name='[Calculation_1463768974569490]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [sentiment] = &apos;positive&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Review negativa (0/1)' datatype='integer' name='[Calculation_1463768974704659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [sentiment] = &apos;negative&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption=' Thumbs up acotado ' datatype='integer' name='[Calculation_1463768974811156]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([thumbs_up], 63)' />
      </column>
      <column caption=' Incongruencia rating-sentimiento' datatype='string' name='[Calculation_1463768975011861]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [rating] &gt;= 4 AND [sentiment] = &apos;negative&apos; THEN &apos;Rating alto, texto negativo&apos;ELSEIF [rating] &lt;= 2 AND [sentiment] = &apos;positive&apos; THEN &apos;Rating bajo, texto positivo&apos;ELSE &apos;Coherente&apos;END' />
      </column>
      <column caption='% incoherente' datatype='integer' name='[Calculation_1463768979566614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1463768975011861]&lt;&gt;&apos;Coherente&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Jitter' datatype='real' name='[Calculation_1463769012051991]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANDOM()' />
      </column>
