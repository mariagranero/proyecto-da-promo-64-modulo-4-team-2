      <aliases enabled='yes' />
      <column caption='%Hombre' datatype='real' default-format='p0%' name='[%Mujeres (copia)_0157822923837443]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [genero] = &quot;Hombre&quot; THEN 1 ELSE 0 END) &#13;&#10;/&#13;&#10;COUNT([genero])' />
      </column>
      <column caption='Edad media' datatype='integer' datatype-customized='true' name='[Calculation_0157822913658880]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(ROUND(AVG([edad]),0))' />
      </column>
      <column caption='%Mujeres' datatype='real' default-format='p0%' name='[Calculation_0157822915121154]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [genero] = &quot;Mujer&quot; THEN 1 ELSE 0 END) &#13;&#10;/&#13;&#10;COUNT([genero])' />
      </column>
      <column caption='% Genero' datatype='real' name='[Calculation_0157822931357702]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id_usuario]) / WINDOW_SUM(COUNT([id_usuario]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Realizó cita' datatype='integer' name='[Calculation_1463768184119304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [realizo_cita] = &apos;Sí&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Hizo ghosting' datatype='integer' name='[Calculation_1463768184221705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [hizo_ghosting] = &apos;Sí&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Eficiencia funnel %' datatype='real' name='[Calculation_1463768184303626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([eficiencia_funnel]) * 100' />
      </column>
      <column caption='Tasa éxito match %' datatype='real' name='[Calculation_1463768184406027]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([tasa_exito_match]) * 100' />
      </column>
      <column caption='Conversión cita %' datatype='real' name='[Calculation_1463768184565772]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([tasa_conversion_cita]) * 100' />
      </column>
      <column caption='Swipes → Likes enviados' datatype='real' name='[Calculation_1463768202395661]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([likes_enviados_mes]) &#13;&#10;/&#13;&#10;SUM([swipes_mes])' />
      </column>
      <column caption='Likes enviados → Matches' datatype='real' name='[Calculation_1463768202571790]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([matches_mes]) &#13;&#10;/&#13;&#10;SUM([likes_enviados_mes])' />
      </column>
      <column caption='Matches → Conversaciones' datatype='real' name='[Calculation_1463768202641423]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([conversaciones_enviadas_mes]) &#13;&#10;/&#13;&#10;SUM([matches_mes])' />
      </column>
      <column caption='Matches → Cita' datatype='real' name='[Calculation_1463768202768400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1463768184119304])&#13;&#10;/&#13;&#10;SUM([matches_mes])' />
      </column>
      <column caption='Eficiencia Funnel Total' datatype='real' name='[Calculation_1463768203173905]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1463768184119304])&#13;&#10;/&#13;&#10;SUM([swipes_mes])' />
      </column>
      <column aggregation='None' caption='Edad (agrupación)' datatype='integer' name='[Edad (agrupación)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[edad]' peg='0' size='2' />
      </column>
